<%- | Array[Hash] $disks, String $action | -%>

# This file is managed by Puppet; changes may be overwritten.
<% $disks.each |$disk| { -%>

check filesystem <%= $disk['name'] %> with path <%= $disk['path'] %>
     if space usage > <%= $disk['space'] %>% then <%= $action %>
     if inode usage > <%= $disk['inode'] %>% then <%= $action %>
<% } -%>

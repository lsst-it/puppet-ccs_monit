<%- | String $interface, String $action | -%>
# This file is managed by Puppet; changes may be overwritten

check network <%= $interface %> with interface <%= $interface %>
  if changed link capacity then <%= $action %>
  if saturation > 90% for 3 cycles then <%= $action %>

check program netspeed with path /usr/local/bin/monit_netspeed timeout 10 seconds
  if status != 0 then <%= $action %>
